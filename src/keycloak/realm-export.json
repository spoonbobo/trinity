{
  "realm": "trinity",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",
  "passwordPolicy": "length(8) and maxLength(128) and notUsername and notEmail",
  "clients": [
    {
      "clientId": "trinity-shell",
      "name": "Trinity AGI Shell",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "trinity-shell-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost/*", "http://localhost:80/*"],
      "webOrigins": ["http://localhost"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost/*"
      }
    }
    ,
    {
      "clientId": "account",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["/realms/trinity/account/*"],
      "webOrigins": ["http://localhost"]
    }
  ],
  "roles": {
    "realm": [
      { "name": "trinity_guest", "description": "Guest role" },
      { "name": "trinity_user", "description": "Standard user" },
      { "name": "trinity_admin", "description": "Administrator" }
    ]
  },
  "defaultRoles": ["trinity_user"],
  "components": {}
}
